# ============================================
# Ask Spurgeon — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Groq (REQUIRED for chat) ---
# Get free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- Vector Store Selection (Local Development) ---
# chroma  = Recommended for quick/local testing (default)
# qdrant  = Use when you want more realistic testing (closer to production)
VECTOR_STORE=chroma

# --- Qdrant Cloud (RECOMMENDED for production) ---
# Free tier: https://cloud.qdrant.io (1GB RAM / 4GB disk, permanent, no card required)
QDRANT_URL=https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=spurgeon_sermons_v1

# --- Vector Store for Local Development ---
# Recommended default for quick/local testing: Chroma (persistent mode)
# Use Qdrant locally when you want more realistic testing (closer to production)

# --- ChromaDB (Recommended for quick local dev) ---
# Easiest option (no Docker):
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=spurgeon_sermons_v1

# Docker option for Chroma:
# VECTOR_STORE=chroma
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_COLLECTION=spurgeon_sermons_v1

# --- Local Qdrant (Better for realistic local testing) ---
# Run: docker compose up -d qdrant
#
# Then use:
# VECTOR_STORE=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=spurgeon_sermons_local
#
# Access the web UI (Dashboard) at:
# http://localhost:6333/dashboard
# (add ?api_key=... if you set one)

# --- Embeddings (optional overrides) ---
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIM=384

# --- LLM Models (Groq free tier friendly) ---
# PRIMARY_MODEL=llama-3.3-70b-versatile
# FALLBACK_MODEL=llama-3.1-8b-instant

# --- Custom LLM (your fine-tuned Spurgeon model via llama.cpp CPU Space on HF Spaces or local) ---
# Set these to use your deployed fine-tuned model instead of (or alongside) Groq.
# LLM_PROVIDER=openai
# CUSTOM_LLM_BASE_URL=https://your-username-your-generator-space.hf.space/v1
# CUSTOM_LLM_API_KEY=hf_dummy                    # Any non-empty string (e.g. hf_dummy). Your custom public HF Space server does NOT require a real OpenAI key.
# CUSTOM_LLM_MODEL=spurgeon-8b
#
# For local testing of the generator:
# CUSTOM_LLM_BASE_URL=http://localhost:7860/v1
# (Start the generator with: cd fine_tuning/spaces/cpu-llama-cpp && python main.py )


# --- Ingestion settings ---
# SERMON_SOURCE_DIR=./data/sermons          # for PDFs
# SERMON_MARKDOWN_DIR=./data/chspurgeon-sermons   # recommended: clone of lyteword/chspurgeon-sermons
# MAX_SERMONS=50                            # start small for MVP (set to 0 or omit for all)

# --- Rate Limiting (per session in Streamlit) ---
# MAX_QUERIES_PER_HOUR=8
# RATE_LIMIT_WINDOW_SECONDS=3600
